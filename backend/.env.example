PORT=5000
FRONTEND_ORIGIN=http://localhost:8080
# Optional: allow multiple origins (comma-separated) for custom domain + Netlify.
# Example: FRONTEND_ORIGINS=https://yourdomain.com,https://your-site.netlify.app
FRONTEND_ORIGINS=

# MongoDB Atlas connection string
# Example: mongodb+srv://username:password@cluster0.abcde.mongodb.net/ssn-hospital?retryWrites=true&w=majority
MONGODB_URI=
