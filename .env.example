# Backend API base URL consumed by src/services/api.ts
# Leave as /api when using the Vite proxy in local development.
VITE_API_BASE_URL=/api

# Dev-only: Vite proxy target for /api requests.
# Set this to your backend server address.
VITE_API_PROXY_TARGET=http://localhost:5000

# Optional: Socket.IO server URL used for realtime updates.
VITE_SOCKET_URL=http://localhost:5000
